{
    "name": "symfinity/ux-blocks",
    "description": "Registry schema and shared test helpers for the Symfinity UX Blocks component family",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://github.com/symfinity/ux-blocks",
    "support": {
        "issues": "https://github.com/symfinity/ux-blocks/issues",
        "source": "https://github.com/symfinity/ux-blocks"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "ux-blocks",
        "twig-components",
        "design-system",
        "registry"
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^7.4||^8.0",
        "symfony/console": "^7.4||^8.0",
        "symfony/dependency-injection": "^7.4||^8.0",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/http-kernel": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0",
        "symfony/process": "^7.4||^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocks\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^7.4||^8.0"
        }
    },
    "suggest": {
        "symfinity/ui-kernel": "Token-driven role CSS and flavours when building styled blocks",
        "symfinity/ui-action": "Native HTTP action semantics for interactive blocks",
        "symfony/ux-icons": "Icon set for roles that use ux:icon (optional per app)"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.3"
}
